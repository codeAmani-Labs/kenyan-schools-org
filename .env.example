# Kenyan Schools Directory - Environment Variables (Hazina-style)
# Copy this to .env.local and fill real values. Never commit secrets.
# See web/DEPLOY.md and web/lib/env.ts

# Database (Neon Postgres)
# After creating via Neon (MCP or dashboard), copy the *pooled* connection string here.
# Use the same for DIRECT_DATABASE_URL if you have a direct one.
# Never commit the real value - see Hazina in lib/env.ts
DATABASE_URL=postgresql://user:pass@host/db?channel_binding=require&sslmode=require
DIRECT_DATABASE_URL=postgresql://user:pass@host/db?channel_binding=require&sslmode=require

# Admin access for /admin routes (use a long random secret)
ADMIN_SECRET=your-long-random-admin-secret-here

# Cloudflare (general API token, account, R2 storage, DNS editing)
# Use the official Cloudflare API token with appropriate scopes (R2:Edit, Zone:Edit, etc.)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_S3_API_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Cloudflare R2 (for evidence uploads)
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=kenyan-schools-evidence  # created via wrangler r2 bucket create using Cloudflare CLI
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.r2.dev   # optional public base url

# Cloudflare DNS editing token (for zone updates if needed)
EDIT_ZONE_DNS_API_TOKEN=your-dns-edit-token

# Porkbun DNS API keys (used to set DNS records for kenyanschools.org to point to Vercel)
PORKBUN_API_KEY=your-porkbun-api-key
PORKBUN_SECRET_KEY=your-porkbun-secret-key

# Site
NEXT_PUBLIC_SITE_URL=https://kenyanschools.org

# Optional: Emails via Resend (for contributor welcome/apply notifications)
RESEND_API_KEY=re_your_resend_key

# Vercel AI Gateway (for AI model access, routing, and observability)
# Get key from Vercel Dashboard → AI → Gateway (keys start with vck_)
AI_GATEWAY_API_KEY=vck_...

# Optional: override GitHub repo (default: codeAmani-Labs/kenyan-schools-org primary)
# GITHUB_REPO=codeAmani-Labs/kenyan-schools-org

# GitHub OAuth (for /apply)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# For local dev only - production values live in Vercel (encrypted)
NODE_ENV=development
