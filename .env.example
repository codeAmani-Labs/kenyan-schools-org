# Kenyan Schools Directory - Environment Variables (Hazina-style)
# Copy this to .env.local and fill real values. Never commit secrets.
# See web/DEPLOY.md and web/lib/env.ts

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Admin access for /admin routes (use a long random secret)
ADMIN_SECRET=your-long-random-admin-secret-here

# Cloudflare R2 (for evidence uploads)
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=kenyan-schools-evidence
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.r2.dev   # optional public base url

# Site
NEXT_PUBLIC_SITE_URL=https://kenyanschool.org

# Optional: Emails via Resend (for contributor welcome/apply notifications)
RESEND_API_KEY=re_your_resend_key

# Optional: override GitHub repo (default: codeAmani-Labs/kenyan-schools-org primary)
# GITHUB_REPO=codeAmani-Labs/kenyan-schools-org

# For local dev only - production values live in Vercel (encrypted)
NODE_ENV=development
