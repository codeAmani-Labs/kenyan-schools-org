// This is your Prisma schema for KenyanSchools.org
// Using Neon Postgres (serverless-friendly)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id                String   @id @default(cuid())
  indexNo           String   @unique // CodeAmani Labs KSO internal index e.g. KSO-0042 - used to distinguish duplicate names
  slug              String   @unique
  name              String
  county            String
  tier              String
  rank              Int?
  gender            String?
  cluster           String?

  // Enrichable wiki-style fields
  shortName         String?
  address           String?
  website           String?
  phone             String?
  email             String?
  lat               Float?
  lng               Float?
  gpsConfidence     String?
  sportsNicknames   String?
  notes             String?
  established       String?

  // Flexible sources/citations stored as JSON
  sources           Json     @default("[]")

  // Timestamps + provenance
  addedAt           DateTime @default(now())
  lastUpdated       DateTime @updatedAt

  suggestions       Suggestion[]
}

model Suggestion {
  id              String    @id @default(cuid())
  schoolId        String?   // null = new school proposal
  school          School?   @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  // For new school proposals
  proposedSchoolName String?
  proposedCounty     String?

  field           String    // e.g. "notes", "website", "NEW_SCHOOL", "lat"
  currentValue    String?
  proposedValue   String

  source          String?   // citation / reference provided by contributor
  contributorName String?
  contributorEmail String?

  status          String    @default("pending") // pending | approved | rejected
  message         String?   // contributor notes / context
  adminNotes      String?

  createdAt       DateTime  @default(now())
  reviewedAt      DateTime?

  attachments     SuggestionAttachment[]
}

model SuggestionAttachment {
  id            String   @id @default(cuid())
  suggestionId  String
  suggestion    Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  // Stored in Cloudflare R2
  r2Key         String   // e.g. "evidence/2026/abc123-evidence.pdf"
  r2Url         String?  // public or signed URL
  filename      String
  contentType   String?
  size          Int?

  createdAt     DateTime @default(now())
}

model ApprovedChange {
  id           String   @id @default(cuid())
  schoolId     String
  suggestionId String?
  field        String
  oldValue     String?
  newValue     String
  appliedAt    DateTime @default(now())
  appliedBy    String?
}

model ContributorApplication {
  id               String   @id @default(cuid())
  fullName         String
  githubUsername   String?
  email            String
  motivation       String
  areasOfInterest  String[]   // e.g. ["data", "research", "dev", "design"]
  experience       String?
  publicListing    Boolean  @default(true)  // Opt-in for public contributors page
  status           String   @default("pending") // pending | approved | rejected
  submittedAt      DateTime @default(now())
  reviewedAt       DateTime?
  reviewerNotes    String?
}
