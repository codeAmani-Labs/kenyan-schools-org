# Hazina Environment Variables (secure pattern)
# 
# This project uses a Hazina-style environment loader (lib/env.ts):
# - Centralized, typed access to all vars
# - Required secret validation at startup
# - Environment variable fallback + encrypted storage ready
# - Works with Vercel (encrypted envs), Neon, Cloudflare R2
#
# Local development:
#   cp .env.example .env.local
#   # Never commit .env.local or any real secrets
#
# Production (Vercel):
#   Set these in Vercel Dashboard → Settings → Environment Variables
#   (Vercel encrypts them at rest)
#
# Advanced / Hazina pattern:
#   Use encrypted secrets with env fallback (see lib/env.ts comments)
#   Or integrate full secrets manager (Doppler, 1Password, Cloudflare, Azure Key Vault, etc.)

# Neon Postgres (required for DB)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neon?sslmode=require"

# Direct URL (optional, for migrations)
# DIRECT_DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neon?sslmode=require"

# Public site URL
NEXT_PUBLIC_SITE_URL="https://kenyanschools.org"

# Admin secret for /admin/suggestions review (strong random value required)
ADMIN_SECRET="your-very-long-random-admin-secret-here"

# Cloudflare R2 Storage (for evidence uploads in contributions)
CLOUDFLARE_R2_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
CLOUDFLARE_R2_BUCKET_NAME="kenyan-schools-evidence"
CLOUDFLARE_R2_PUBLIC_URL="https://pub-xxx.r2.dev"   # or your custom domain

# Optional (used for contribution GitHub links)
GITHUB_REPO="your-org/kenyan-schools-org"

# Email for new contributor applications (sent to contributors@codeamanilabs.org)
# Uses Resend (recommended for Vercel). Get free key at resend.com
RESEND_API_KEY=""

# Vercel AI Gateway (for AI features / model access)
# Create via Vercel Dashboard → AI → Gateway. Keys start with vck_
AI_GATEWAY_API_KEY=""

# GitHub OAuth for /apply prefill (optional, for "Sign in with GitHub")
# Create OAuth app at https://github.com/settings/applications/new
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Porkbun DNS API (for connecting domain to Vercel via API)
PORKBUN_API_KEY=""
PORKBUN_SECRET_KEY=""

# Additional Cloudflare (general API, not just R2)
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ACCESS_KEY_ID=""
CLOUDFLARE_SECRET_ACCESS_KEY=""
CLOUDFLARE_S3_API_ENDPOINT=""
EDIT_ZONE_DNS_API_TOKEN=""
